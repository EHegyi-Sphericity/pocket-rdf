# Cross-graph query: find authors that appear in more than one catalog.

PREFIX ex: <http://example.org/library/>

SELECT ?authorName (COUNT(DISTINCT ?graph) AS ?catalogCount)
WHERE {
    GRAPH ?graph {
        ?author a       ex:Author ;
                ex:name ?authorName .
    }
}
GROUP BY ?authorName
HAVING (COUNT(DISTINCT ?graph) > 1)

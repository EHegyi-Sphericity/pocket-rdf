@prefix ex:   <http://example.org/library/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# A book missing the required ex:title property (violates the shapes).
ex:book-invalid  a  ex:Book ;
    ex:author     ex:author-tolkien ;
    ex:genre      ex:genre-fantasy ;
    ex:published  1977 ;
    ex:pages      365 .

# An author missing the required ex:name property (violates the shapes).
ex:author-unknown  a  ex:Author ;
    ex:birthYear   1900 .
